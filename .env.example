GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_GENAI_API_KEY=your-genai-api-key
FIREBASE_WEB_API_KEY=your-firebase-web-api-key
GOOGLE_CLOUD_REGION=asia-south1
FIRESTORE_DATABASE=(default)
USE_GO_TUTOR_SERVICE=true
TUTOR_SERVICE_URL=http://localhost:8081
GO_TUTOR_MODEL=gemini-2.0-flash
CONTENT_DIR=./content
ENABLE_NCERT_RAG=true
NCERT_VECTOR_INDEX_PATH=./content/index/ncert_embeddings.jsonl
NCERT_VECTOR_INDEX_GCS_URI=
NCERT_VECTOR_INDEX_GCS_PUBLIC_URL=
NCERT_TOP_K=4
GOOGLE_PLAY_PACKAGE_NAME=com.smartstudybuddy.app
GOOGLE_PLAY_API_KEY=
APPLE_SHARED_SECRET=
ALLOW_TIER_ENDPOINT=false
GOOGLE_RTDN_BEARER_TOKEN=
APPLE_SERVER_NOTIFICATIONS_BEARER_TOKEN=
RECONCILE_BEARER_TOKEN=

# Optional: Secret Manager names for deploy script (recommended for production)
GOOGLE_GENAI_API_KEY_SECRET=
APPLE_SHARED_SECRET_SECRET=
FIREBASE_WEB_API_KEY_SECRET=
GOOGLE_RTDN_BEARER_TOKEN_SECRET=
APPLE_SERVER_NOTIFICATIONS_BEARER_TOKEN_SECRET=
RECONCILE_BEARER_TOKEN_SECRET=
